---
import {copy} from '../content/copy'
---

<section id="about" class="mission">
  <div class="container">
    <div class="eyebrow">{copy.missionEyebrow}</div>
    <h2 class="lead">{copy.missionLead}</h2>
    <div class="rule"></div>
    <details class="more">
      <summary>{copy.missionSummary}</summary>
      <div class="body">
        {copy.missionBody.map((paragraph) => <p class="para">{paragraph}</p>)}
      </div>
    </details>
  </div>
</section>

<style>
  .mission {
    padding: 64px 0 56px;
    background: var(--color-cream);
  }

  @media (max-width: 640px) {
    .mission {
      padding: 48px 0 40px;
    }
  }

  .eyebrow {
    font-family: var(--font-sans);
    font-size: 10px;
    letter-spacing: 0.28em;
    color: var(--color-bronze);
  }

  .lead {
    font-family: var(--font-serif);
    font-size: clamp(22px, 3.2vw, 36px);
    color: var(--color-navy);
    line-height: 1.3;
    margin: 12px 0 0;
    font-weight: 500;
    max-width: 36rem;
    letter-spacing: -0.005em;
  }

  .rule {
    width: 60px;
    height: 1px;
    background: var(--color-bronze);
    margin: 24px 0 0;
  }

  .more {
    margin-top: 20px;
    font-family: var(--font-sans);
  }

  .more summary {
    cursor: pointer;
    font-size: 13px;
    font-weight: 600;
    color: var(--color-teal);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    list-style: none;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 4px 0;
  }

  .more summary::-webkit-details-marker {
    display: none;
  }

  .more summary::after {
    content: '↓';
    font-size: 14px;
    transition: transform 0.2s ease;
  }

  .more[open] summary::after {
    transform: rotate(180deg);
  }

  .body {
    margin-top: 16px;
    max-width: 38rem;
  }

  .para {
    font-family: var(--font-serif);
    color: #2a2a2a;
    font-size: 15px;
    line-height: 1.7;
    margin: 0 0 14px;
  }
</style>
