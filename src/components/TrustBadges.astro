---
import {copy} from '../content/copy'

const iconSvg = {
  licensed: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2 4 5v6c0 5 3.5 9 8 11 4.5-2 8-6 8-11V5l-8-3z"/><path d="m9 12 2 2 4-4"/></svg>`,
  curriculum: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>`,
  music: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>`,
  updates: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>`,
} as const
---

<section class="section">
  <div class="container">
    <div class="grid">
      {copy.badges.map((badge) => (
        <div class="badge">
          <div class="icon" set:html={iconSvg[badge.key]}></div>
          <div>
            <div class="title">{badge.title}</div>
            <div class="subtitle">{badge.subtitle}</div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .section {
    background: var(--color-cream-deep);
    padding: 32px 0;
    font-family: var(--font-sans);
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 28px;
  }

  @media (max-width: 900px) {
    .grid {
      grid-template-columns: 1fr 1fr;
      gap: 24px 20px;
    }
  }

  @media (max-width: 420px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }

  .badge {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    font-size: 11.5px;
    color: var(--color-navy);
    line-height: 1.4;
    text-align: left;
  }

  .icon {
    color: var(--color-teal);
    flex-shrink: 0;
    display: block;
  }

  .icon :global(svg) {
    width: 28px;
    height: 28px;
    display: block;
  }

  .title {
    font-weight: 600;
    color: var(--color-navy);
    font-size: 13px;
    letter-spacing: -0.005em;
  }

  .subtitle {
    color: #6a5a3a;
    margin-top: 3px;
    font-size: 11.5px;
    line-height: 1.4;
  }
</style>
