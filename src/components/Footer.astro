---
import {contact} from '../content/contact'
---

<footer class="footer">
  <div class="container inner">
    <div class="brand">
      <img src="/logo.svg" alt="" class="footer-logo" width="52" height="52" />
      <div class="brand-name">{contact.name}</div>
      <div class="brand-tag">{contact.tagline}</div>
    </div>
    <div class="contact-block">
      <div class="row">
        <span class="icon">📞</span>
        <a href={contact.phoneHref}>{contact.phone}</a>
      </div>
      <div class="row">
        <span class="icon">📍</span>
        <a href={contact.addressHref} target="_blank" rel="noopener noreferrer">{contact.address}</a>
      </div>
      <div class="row">
        <span class="icon">🕒</span>
        <span>{contact.hours}</span>
        <span class="muted"> · {contact.hoursNote}</span>
      </div>
      <div class="row">
        <span class="icon">📷</span>
        <a href={contact.instagram} target="_blank" rel="noopener noreferrer">{contact.handle}</a>
        <span class="muted"> · Instagram</span>
        <span class="muted"> · </span>
        <a href={contact.facebook} target="_blank" rel="noopener noreferrer">Facebook</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--color-ink);
    color: var(--color-bronze);
    padding: 40px 0 calc(40px + env(safe-area-inset-bottom));
    font-family: var(--font-sans);
    font-size: 13px;
    line-height: 1.9;
  }

  @media (max-width: 720px) {
    .footer {
      padding-bottom: calc(76px + env(safe-area-inset-bottom));
    }
  }

  .inner {
    display: grid;
    gap: 28px;
  }

  @media (min-width: 900px) {
    .inner {
      grid-template-columns: minmax(200px, 280px) 1fr;
      gap: 48px;
      align-items: start;
    }
  }

  .brand {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 8px;
  }

  .footer-logo {
    width: 52px;
    height: 52px;
    background: var(--color-cream);
    border-radius: 8px;
    padding: 4px;
    box-sizing: border-box;
    display: block;
  }

  .brand-name {
    color: var(--color-cream);
    font-family: var(--font-serif);
    font-size: 17px;
    font-weight: 500;
    letter-spacing: -0.005em;
    margin-top: 4px;
  }

  .brand-tag {
    color: var(--color-bronze);
    font-size: 12px;
    line-height: 1.5;
    max-width: 20rem;
  }

  .contact-block {
    display: grid;
    gap: 4px;
  }

  .footer a {
    color: var(--color-cream);
  }

  .footer a:hover {
    text-decoration: underline;
  }

  .icon {
    margin-right: 6px;
  }

  .muted {
    color: var(--color-bronze);
  }
</style>
