---
import {contact} from '../content/contact'
---

<footer class="footer">
  <div class="container inner">
    <div class="brand">
      <img src="/logo.svg" alt="" class="footer-logo" width="52" height="52" />
      <div class="brand-name">{contact.name}</div>
      <div class="brand-tag">{contact.tagline}</div>
    </div>
    <div class="contact-block">
      <div class="row">
        <span class="icon"><svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg></span>
        <a href={contact.phoneHref}>{contact.phone}</a>
      </div>
      <div class="row">
        <span class="icon"><svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg></span>
        <a href={contact.addressHref} target="_blank" rel="noopener noreferrer">{contact.address}</a>
      </div>
      <div class="row">
        <span class="icon"><svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg></span>
        <span>{contact.hours}</span>
        <span class="muted"> · {contact.hoursNote}</span>
      </div>
      <div class="row">
        <span class="icon"><svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg></span>
        <a href={contact.instagram} target="_blank" rel="noopener noreferrer">{contact.handle}</a>
        <span class="muted"> · Instagram</span>
        <span class="muted"> · </span>
        <a href={contact.facebook} target="_blank" rel="noopener noreferrer">Facebook</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--color-ink);
    color: var(--color-bronze);
    padding: 40px 0 calc(40px + env(safe-area-inset-bottom));
    font-family: var(--font-sans);
    font-size: 13px;
    line-height: 1.9;
  }

  @media (max-width: 720px) {
    .footer {
      padding-bottom: calc(76px + env(safe-area-inset-bottom));
    }
  }

  .inner {
    display: grid;
    gap: 28px;
  }

  @media (min-width: 900px) {
    .inner {
      grid-template-columns: minmax(200px, 280px) 1fr;
      gap: 48px;
      align-items: start;
    }
  }

  .brand {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 8px;
  }

  .footer-logo {
    width: 52px;
    height: 52px;
    background: var(--color-cream);
    border-radius: 8px;
    padding: 4px;
    box-sizing: border-box;
    display: block;
  }

  .brand-name {
    color: var(--color-cream);
    font-family: var(--font-serif);
    font-size: 17px;
    font-weight: 500;
    letter-spacing: -0.005em;
    margin-top: 4px;
  }

  .brand-tag {
    color: var(--color-bronze);
    font-size: 12px;
    line-height: 1.5;
    max-width: 20rem;
  }

  .contact-block {
    display: grid;
    gap: 4px;
  }

  .footer a {
    color: var(--color-cream);
  }

  .footer a:hover {
    text-decoration: underline;
  }

  .icon {
    margin-right: 6px;
    display: inline-flex;
    align-items: center;
    vertical-align: middle;
  }

  .muted {
    color: var(--color-bronze);
  }
</style>
