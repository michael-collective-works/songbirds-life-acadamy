---
import {Image} from 'astro:assets'
import piano from '../assets/photos/piano-headphones.jpg'
---

<section class="music-band">
  <div class="container">
    <div class="layout">
      <figure class="photo">
        <Image
          src={piano}
          alt="A young girl at a piano wearing over-ear headphones, a vinyl record in the foreground"
          widths={[320, 480, 720, 960]}
          sizes="(min-width: 900px) 420px, 100vw"
          format="webp"
          quality={82}
        />
      </figure>
      <div class="caption">
        <div class="mark">♪</div>
        <div class="text">Music is not an activity here — it is the daily rhythm of our classrooms.</div>
        <div class="sub">From soft lullabies to clapping, humming, dancing, and instrumentation.</div>
      </div>
    </div>
  </div>
</section>

<style>
  .music-band {
    background: var(--color-navy);
    color: var(--color-cream);
    padding: 56px 0;
  }

  @media (min-width: 900px) {
    .music-band {
      padding: 80px 0;
    }
  }

  .layout {
    display: grid;
    gap: 28px;
    justify-items: center;
    align-items: center;
  }

  @media (min-width: 900px) {
    .layout {
      grid-template-columns: minmax(300px, 460px) 1fr;
      gap: 56px;
      justify-items: start;
    }
  }

  .photo {
    margin: 0;
    width: 100%;
    max-width: 460px;
    border-radius: 6px;
    overflow: hidden;
    background: var(--color-ink);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.35);
  }

  .photo :global(img) {
    width: 100%;
    height: auto;
    display: block;
  }

  .caption {
    max-width: 34rem;
    text-align: center;
  }

  @media (min-width: 900px) {
    .caption {
      text-align: left;
    }
  }

  .mark {
    font-family: var(--font-serif);
    font-size: 60px;
    color: var(--color-gold);
    line-height: 1;
    margin-bottom: 10px;
  }

  .text {
    font-family: var(--font-serif);
    font-size: clamp(20px, 2.4vw, 30px);
    line-height: 1.3;
    font-weight: 400;
    color: var(--color-cream);
  }

  .sub {
    margin-top: 14px;
    font-family: var(--font-sans);
    font-size: 14px;
    line-height: 1.6;
    color: var(--color-cream);
    opacity: 0.78;
    max-width: 30rem;
  }
</style>
