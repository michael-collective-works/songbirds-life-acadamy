---
import {contact} from '../content/contact'
---

<nav class="nav">
  <div class="container nav-inner">
    <a href="/" class="nav-brand" aria-label={`${contact.name} home`}>
      <img src="/logo.svg" alt="" class="nav-logo" width="40" height="40" />
      <span class="nav-wordmark">
        <span class="nav-wordmark-main">{contact.shortName.toUpperCase()}</span>
        <span class="nav-wordmark-sub">for the Youth</span>
      </span>
    </a>
    <div class="nav-links">
      <a href="#about">About</a>
      <a href="#programs">Programs</a>
      <a href={contact.inquiryFormUrl} target="_blank" rel="noopener noreferrer" class="nav-cta">
        Inquire ↗
      </a>
    </div>
  </div>
</nav>

<style>
  .nav {
    background: var(--color-navy);
    color: var(--color-cream);
    font-family: var(--font-sans);
    font-size: 13px;
    letter-spacing: 0.08em;
  }

  .nav-inner {
    padding-top: 14px;
    padding-bottom: 14px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .nav-brand {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-weight: 600;
  }

  .nav-logo {
    width: 40px;
    height: 40px;
    display: block;
    background: var(--color-cream);
    border-radius: 6px;
    padding: 4px;
    box-sizing: border-box;
  }

  .nav-wordmark {
    display: flex;
    flex-direction: column;
    line-height: 1.15;
  }

  .nav-wordmark-main {
    font-size: 13px;
    letter-spacing: 0.08em;
  }

  .nav-wordmark-sub {
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-gold);
    opacity: 0.85;
    margin-top: 2px;
  }

  @media (max-width: 420px) {
    .nav-wordmark-main {
      font-size: 11px;
      letter-spacing: 0.06em;
    }

    .nav-wordmark-sub {
      font-size: 9px;
    }
  }

  .nav-links {
    display: flex;
    gap: 22px;
    align-items: center;
  }

  .nav-cta {
    color: var(--color-gold);
    font-weight: 600;
  }

  @media (max-width: 520px) {
    .nav-links a:not(.nav-cta) {
      display: none;
    }
  }
</style>
