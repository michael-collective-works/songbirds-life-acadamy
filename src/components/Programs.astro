---
import {copy} from '../content/copy'
import {contact} from '../content/contact'

const accentVar = {
  'burnt-orange': 'var(--color-burnt-orange)',
  'teal': 'var(--color-teal)',
  'gold': 'var(--color-gold)',
  'navy': 'var(--color-navy)',
  'bronze': 'var(--color-bronze)',
} as const

const ctaUrlFor = (key: string | null): string | null => {
  if (!key) return null

  if (key === 'musicLessonsSignupUrl') return contact.musicLessonsSignupUrl

  return contact.inquiryFormUrl
}
---

<section id="programs" class="programs">
  <div class="container">
    <div class="eyebrow">{copy.programsEyebrow}</div>
    <h2 class="lead">{copy.programsLead}</h2>
    <ul class="grid">
      {copy.programs.map((p) => {
        const url = ctaUrlFor(p.ctaKey)

        return (
          <li class="card" style={`--accent:${accentVar[p.accent]}`}>
            <div class="ages">{p.ages}</div>
            <h3 class="name">{p.name}</h3>
            <p class="desc">{p.description}</p>
            {p.ctaLabel && url && (
              <a class="cta" href={url} target="_blank" rel="noopener noreferrer">
                {p.ctaLabel} ↗
              </a>
            )}
          </li>
        )
      })}
    </ul>
  </div>
</section>

<style>
  .programs {
    padding: 64px 0 56px;
    background: var(--color-cream);
  }

  .eyebrow {
    font-family: var(--font-sans);
    font-size: 11px;
    letter-spacing: 0.28em;
    color: var(--color-navy);
  }

  .lead {
    font-family: var(--font-serif);
    font-size: clamp(22px, 3.4vw, 34px);
    color: var(--color-navy);
    line-height: 1.3;
    margin: 10px 0 28px;
    font-weight: 500;
    max-width: 34rem;
    letter-spacing: -0.005em;
  }

  .grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 18px;
  }

  @media (max-width: 900px) {
    .grid {
      grid-template-columns: 1fr;
      gap: 14px;
    }
  }

  .card {
    background: #fff;
    border-top: 3px solid var(--accent);
    padding: 22px 22px 24px;
    border-radius: 3px;
    box-shadow: var(--shadow-soft);
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .ages {
    font-family: var(--font-sans);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-weight: 700;
    color: var(--accent);
  }

  .name {
    font-family: var(--font-serif);
    font-size: 22px;
    color: var(--color-navy);
    line-height: 1.2;
    margin: 0;
    font-weight: 500;
    letter-spacing: -0.005em;
  }

  .desc {
    font-family: var(--font-serif);
    font-size: 14px;
    line-height: 1.65;
    color: #2a2a2a;
    margin: 4px 0 0;
    flex: 1;
  }

  .cta {
    align-self: flex-start;
    margin-top: 14px;
    font-family: var(--font-sans);
    font-size: 13px;
    font-weight: 600;
    color: var(--accent);
    min-height: 44px;
    padding: 10px 18px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1.5px solid var(--accent);
    border-radius: 4px;
    letter-spacing: 0.02em;
  }

  .cta:hover {
    background: var(--accent);
    color: var(--color-cream);
  }
</style>
