---
const items = [
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2 4 5v6c0 5 3.5 9 8 11 4.5-2 8-6 8-11V5l-8-3z"/><path d="m9 12 2 2 4-4"/></svg>`,
    title: 'Louisiana Dept. of Education',
    subtitle: 'Licensed early learning center',
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>`,
    title: 'Creative Curriculum®',
    subtitle: 'Research-based program',
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>`,
    title: 'Music & Movement Daily',
    subtitle: 'Singing, dancing, and instrumentation',
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
    title: 'Low Teacher-to-Child Ratios',
    subtitle: 'Personalized care for every child',
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>`,
    title: 'Sensory-Rich Classrooms',
    subtitle: 'Exploration and hands-on learning',
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>`,
    title: 'Daily Photo Updates',
    subtitle: 'You never miss a moment',
  },
]
---

<section class="section">
  <div class="container">
    <div class="eyebrow">WHY SONGBIRDS</div>
    <ul class="grid">
      {items.map((item) => (
        <li class="item">
          <div class="icon" set:html={item.icon}></div>
          <div class="text">
            <div class="title">{item.title}</div>
            <div class="subtitle">{item.subtitle}</div>
          </div>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .section {
    background: var(--color-cream-deep);
    padding: 56px 0 64px;
    font-family: var(--font-sans);
  }

  .eyebrow {
    font-family: var(--font-sans);
    font-size: 11px;
    letter-spacing: 0.28em;
    color: var(--color-navy);
    margin-bottom: 32px;
  }

  .grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
  }

  @media (max-width: 900px) {
    .grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 24px 20px;
    }
  }

  @media (max-width: 560px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }

  .item {
    display: flex;
    align-items: flex-start;
    gap: 14px;
  }

  .icon {
    color: var(--color-teal);
    flex-shrink: 0;
    display: block;
  }

  .icon :global(svg) {
    width: 28px;
    height: 28px;
    display: block;
  }

  .text {
    display: flex;
    flex-direction: column;
    gap: 3px;
  }

  .title {
    font-size: 13px;
    font-weight: 700;
    color: var(--color-navy);
    letter-spacing: -0.005em;
    line-height: 1.3;
  }

  .subtitle {
    font-size: 12px;
    color: #6a5a3a;
    line-height: 1.4;
  }
</style>
