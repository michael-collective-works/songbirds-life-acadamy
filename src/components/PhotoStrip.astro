---
import {Image} from 'astro:assets'
import train from '../assets/photos/train-play.jpg'
import alphabet from '../assets/photos/alphabet-mat.jpg'
---

<section class="strip">
  <div class="large">
    <Image
      src={train}
      alt="A toddler in a polo shirt playing with a wooden train set on the classroom floor, a drum kit behind him"
      widths={[480, 900, 1400]}
      sizes="(max-width: 768px) 100vw, 66vw"
      format="webp"
      quality={80}
    />
  </div>
  <div class="small">
    <Image
      src={alphabet}
      alt="Top-down view of a child on a colorful alphabet foam mat surrounded by learning toys"
      widths={[320, 640, 960]}
      sizes="(max-width: 768px) 100vw, 33vw"
      format="webp"
      quality={80}
    />
  </div>
</section>

<style>
  .strip {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 6px;
    padding: 0 22px;
  }

  @media (max-width: 640px) {
    .strip {
      grid-template-columns: 1fr;
    }
  }

  .strip :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 4px;
  }

  .large, .small {
    aspect-ratio: 4/3;
    overflow: hidden;
    border-radius: 4px;
  }
</style>
